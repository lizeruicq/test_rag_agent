# RAG Knowledge Base System - Environment Variables
# Ollama local models + Qdrant vector database

# ============================================
# Ollama Configuration (Required)
# ============================================

# Ollama server host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Embedding model: qwen3-embedding:4b
# LLM model: qwen3:4b
# (Models are configured in code, no need to set here)

# ============================================
# Vector Database Configuration (Choose one)
# ============================================

# Option 1: Use Qdrant Docker service (recommended)
# Start with: docker-compose up -d qdrant
# Or: docker run -d -p 6333:6333 -v ./qdrant_storage:/qdrant/storage qdrant/qdrant
QDRANT_URL=http://localhost:6333

# Option 2: Use local file storage (if QDRANT_URL is not set)
# PERSIST_PATH=./persist_data

# ============================================
# Streamlit Configuration (Optional)
# ============================================
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
